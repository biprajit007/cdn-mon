# ── Portal Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string
SESSION_HOURS=24

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
AUTO_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=cdn-monitor-2026!

# ── Ingest ───────────────────────────────────────────────────────────────────
# Token agents must send in X-Agent-Token header (new /api/ingest endpoint)
INGEST_TOKEN=change-me-to-a-random-string
# Legacy API key for rocks-cdn agent (X-API-Key header on /api/metrics)
LEGACY_API_KEY=change-me

# ── Data Retention ───────────────────────────────────────────────────────────
RETENTION_DAYS=30
